{
  "name": "maths-pack-it",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "lsof -ti :4005 | xargs kill -9 2>/dev/null; vite",
    "prebuild": "node scripts/stamp-manifest.mjs stamp",
    "build": "tsc -b && vite build",
    "postbuild": "node scripts/stamp-manifest.mjs restore",
    "lint": "eslint .",
    "preview": "vite preview",
